{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json",
  "title": "OpenUISpec Custom Contract",
  "description": "Custom contract extension — root key must be x_ prefixed, value follows the standard contract anatomy",
  "type": "object",
  "minProperties": 1,
  "maxProperties": 1,
  "propertyNames": {
    "pattern": "^x_[a-z][a-z0-9_]*$"
  },
  "additionalProperties": {
    "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/contract_def"
  },
  "$defs": {
    "contract_def": {
      "type": "object",
      "description": "A custom contract definition following the standard contract anatomy",
      "properties": {
        "semantic": {
          "type": "string",
          "description": "Human-readable description of this contract's purpose"
        },
        "props": {
          "type": "object",
          "description": "Typed property definitions for this contract",
          "additionalProperties": {
            "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/prop_def"
          }
        },
        "states": {
          "type": "object",
          "description": "UI interaction states (e.g. idle, active, disabled, loading, error) — each key is a state name. These are visual/interaction states, not business logic states.",
          "additionalProperties": {
            "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/state_def"
          }
        },
        "a11y": {
          "type": "object",
          "description": "Accessibility requirements",
          "properties": {
            "role": {
              "type": "string",
              "description": "ARIA/accessibility role"
            },
            "label": {
              "type": "string",
              "description": "Accessibility label source (usually a props reference)"
            },
            "traits": {
              "type": "object",
              "description": "Per-state accessibility traits",
              "additionalProperties": true
            },
            "focus": {
              "type": "object",
              "description": "Focus and keyboard interaction definitions",
              "additionalProperties": true
            }
          },
          "required": ["role", "label"],
          "additionalProperties": true
        },
        "tokens": {
          "description": "Per-variant visual token bindings",
          "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_object"
        },
        "platform_mapping": {
          "type": "object",
          "description": "Per-platform native component mapping",
          "properties": {
            "ios": {
              "type": "object",
              "additionalProperties": true
            },
            "android": {
              "type": "object",
              "additionalProperties": true
            },
            "web": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "dependencies": {
          "type": "object",
          "description": "Per-platform library/framework requirements",
          "additionalProperties": {
            "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/dependency_def"
          }
        },
        "generation": {
          "type": "object",
          "description": "AI generation compliance hints",
          "properties": {
            "must_handle": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Requirements the generator MUST implement"
            },
            "should_handle": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Requirements the generator SHOULD implement"
            },
            "may_handle": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Optional enhancements the generator MAY implement"
            }
          },
          "additionalProperties": false
        },
        "test_cases": {
          "type": "array",
          "description": "Behavioral verification scenarios",
          "items": {
            "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/test_case"
          }
        }
      },
      "required": ["semantic", "props", "states", "a11y", "tokens", "platform_mapping"],
      "additionalProperties": false
    },
    "prop_def": {
      "type": "object",
      "description": "A single prop definition",
      "properties": {
        "type": {
          "type": "string",
          "description": "Data type of this prop"
        },
        "required": {
          "type": "boolean"
        },
        "default": {},
        "description": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowed values for enum types"
        },
        "position": {
          "type": "string",
          "description": "UI position hint"
        },
        "binding": {
          "type": "boolean",
          "description": "Whether this prop supports two-way data binding"
        },
        "condition": {
          "type": "string",
          "description": "Condition when this prop is applicable"
        }
      },
      "required": ["type"],
      "additionalProperties": false
    },
    "state_def": {
      "type": "object",
      "description": "A single UI interaction state",
      "properties": {
        "semantic": {
          "type": "string"
        },
        "transitions_to": {
          "type": "array",
          "items": { "type": "string" },
          "description": "States this state can transition to"
        },
        "duration": {
          "type": "string",
          "description": "Transition duration token reference"
        },
        "behavior": {
          "type": "string",
          "description": "Behavioral description of this state"
        },
        "condition": {
          "type": "string",
          "description": "Condition that triggers this state"
        },
        "feedback": {
          "type": "string",
          "description": "User feedback during this state"
        },
        "label_override": {
          "type": "string",
          "description": "Accessibility label override for this state"
        },
        "style": {
          "type": "object",
          "description": "Visual style overrides for this state",
          "additionalProperties": true
        },
        "visual": {
          "type": "string",
          "description": "Visual description of this state"
        }
      },
      "additionalProperties": false
    },
    "token_object": {
      "type": "object",
      "description": "Recursive token object. If a `states` key is present, it must use the documented interactive state-role shape.",
      "properties": {
        "states": {
          "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/state_role_map"
        }
      },
      "additionalProperties": {
        "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_value"
      }
    },
    "token_value": {
      "description": "Any token value, including nested token objects and arrays.",
      "oneOf": [
        {
          "type": ["string", "number", "boolean", "null"]
        },
        {
          "type": "array",
          "items": {
            "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_value"
          }
        },
        {
          "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_object"
        }
      ]
    },
    "state_role_map": {
      "type": "object",
      "description": "Map of state names to visual-role overrides.",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/state_visual_roles"
      }
    },
    "state_visual_roles": {
      "type": "object",
      "description": "Visual-role overrides available inside token `states` maps.",
      "properties": {
        "background": { "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_value" },
        "text": { "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_value" },
        "icon": { "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_value" },
        "border": { "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_value" },
        "badge_background": { "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_value" },
        "badge_text": { "$ref": "https://openuispec.rsteam.uz/schema/custom-contract.schema.json#/$defs/token_value" }
      },
      "additionalProperties": false
    },
    "dependency_def": {
      "type": "object",
      "description": "Platform-specific dependencies",
      "properties": {
        "frameworks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required frameworks"
        },
        "libraries": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required libraries"
        },
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required packages"
        }
      },
      "additionalProperties": false
    },
    "test_case": {
      "type": "object",
      "description": "A behavioral test case",
      "properties": {
        "id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "given": {
          "type": "string"
        },
        "when": {
          "type": "string"
        },
        "then": {
          "type": "string"
        }
      },
      "required": ["id", "description", "given", "when", "then"],
      "additionalProperties": false
    }
  }
}
