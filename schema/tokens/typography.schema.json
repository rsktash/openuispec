{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openuispec.rsteam.uz/schema/tokens/typography.schema.json",
  "title": "OpenUISpec Typography Tokens",
  "description": "Font families and type scale definitions",
  "type": "object",
  "required": [
    "typography"
  ],
  "additionalProperties": false,
  "properties": {
    "typography": {
      "type": "object",
      "properties": {
        "font_family": {
          "type": "object",
          "description": "Named font family definitions",
          "additionalProperties": {
            "$ref": "https://openuispec.rsteam.uz/schema/tokens/typography.schema.json#/$defs/font_family_entry"
          }
        },
        "scale": {
          "type": "object",
          "description": "Named type scale entries",
          "additionalProperties": {
            "$ref": "https://openuispec.rsteam.uz/schema/tokens/typography.schema.json#/$defs/scale_entry"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "font_family_entry": {
      "type": "object",
      "properties": {
        "semantic": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "fallback_strategy": {
          "type": "string"
        },
        "platform": {
          "type": "object",
          "properties": {
            "ios": {
              "type": "object",
              "additionalProperties": true
            },
            "android": {
              "type": "object",
              "additionalProperties": true
            },
            "web": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        },
        "generation_notes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Sparse guidance for AI generators. Use [web]/[ios]/[android] tags for platform-specific notes."
        }
      },
      "required": [
        "value"
      ],
      "additionalProperties": false
    },
    "scale_entry": {
      "type": "object",
      "properties": {
        "semantic": {
          "type": "string"
        },
        "size": {
          "$ref": "https://openuispec.rsteam.uz/schema/defs/common.schema.json#/$defs/size_value"
        },
        "weight": {
          "type": "integer"
        },
        "tracking": {
          "type": "number"
        },
        "line_height": {
          "type": "number"
        },
        "transform": {
          "type": "string",
          "enum": [
            "uppercase",
            "lowercase",
            "capitalize",
            "none"
          ]
        },
        "generation_notes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Sparse guidance for AI generators. Use [web]/[ios]/[android] tags for platform-specific notes."
        }
      },
      "required": [
        "size",
        "weight",
        "line_height"
      ],
      "additionalProperties": false
    }
  }
}
