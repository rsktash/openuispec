{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openuispec.rsteam.uz/schema/openuispec.schema.json",
  "title": "OpenUISpec Root Manifest",
  "description": "Root manifest file (openuispec.yaml) defining project, includes, generation, data model, and API",
  "type": "object",
  "required": [
    "spec_version",
    "project",
    "includes"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_version": {
      "type": "string",
      "description": "OpenUISpec version (e.g. '0.1')"
    },
    "project": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "includes": {
      "type": "object",
      "description": "Paths to spec component directories",
      "properties": {
        "tokens": {
          "type": "string",
          "description": "Visual design tokens — colors, typography, spacing, elevation, motion. Affects UI rendering only, not business logic."
        },
        "contracts": {
          "type": "string",
          "description": "Reusable UI component definitions — buttons, inputs, lists, surfaces. Each contract specifies visual props, UI interaction states (pressed, disabled, loading), and accessibility. These are UI rendering specifications, not business logic or domain state machines."
        },
        "screens": {
          "type": "string",
          "description": "Screen layouts composed from contracts — defines what UI components appear on each screen, their data bindings, and visual arrangement."
        },
        "flows": {
          "type": "string",
          "description": "Multi-screen navigation journeys — defines screen sequences, transitions, and navigation triggers. UI navigation structure, not business workflow logic."
        },
        "platform": {
          "type": "string",
          "description": "Per-target platform overrides — native UI behavior, framework-specific generation config. One file per target (ios.yaml, android.yaml, web.yaml)."
        },
        "locales": {
          "type": "string",
          "description": "Localization string files — one JSON file per supported locale containing translated UI text."
        },
        "components": {
          "type": "string",
          "description": "Reusable component compositions — each YAML file defines a component as a composition of contracts with named slots, states, and variants."
        }
      },
      "required": [
        "tokens",
        "contracts",
        "screens",
        "flows",
        "platform",
        "locales"
      ],
      "additionalProperties": false
    },
    "i18n": {
      "type": "object",
      "description": "Internationalization configuration",
      "properties": {
        "default_locale": {
          "type": "string"
        },
        "supported_locales": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback_strategy": {
          "type": "string",
          "enum": [
            "default",
            "key",
            "empty"
          ]
        }
      },
      "required": [
        "default_locale",
        "supported_locales"
      ],
      "additionalProperties": false
    },
    "generation": {
      "type": "object",
      "description": "Code generation targets and output format",
      "properties": {
        "targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extra_rules": {
          "type": "array",
          "description": "Project-wide authoring and generation conventions for AI, including optional scoped hint labels such as [common], [ios], [android], and [web].",
          "items": {
            "type": "string"
          }
        },
        "output_dir": {
          "type": "object",
          "description": "Per-target output directory (relative to openuispec.yaml). Defaults to generated/<target>/<project_name> if not set.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "code_roots": {
          "type": "object",
          "description": "Additional project code roots used as generation context.",
          "properties": {
            "backend": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "output_format": {
          "type": "object",
          "description": "Per-target generation config",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "language": {
                "type": "string"
              },
              "framework": {
                "type": "string"
              },
              "min_version": {
                "type": "string"
              },
              "min_sdk": {
                "type": "integer"
              },
              "bundler": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "shared": {
          "type": "object",
          "description": "Named shared code layers that span multiple targets (e.g. KMP common modules)",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "platforms": {
                "type": "array",
                "items": { "type": "string" }
              },
              "language": {
                "type": "string"
              },
              "root": {
                "type": "string"
              },
              "paths": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "tracks": {
                "type": "array",
                "description": "Spec categories this shared layer tracks for hash-based drift detection. Optional — when omitted, the layer relies on scope alone. Categories: manifest (project config, data models, API endpoints), tokens (visual design tokens — UI only), contracts (reusable UI component definitions — UI only, not business logic), screens (screen layouts — UI only), flows (navigation journeys — UI only), platform (per-target overrides — UI only), locales (translated UI strings).",
                "items": {
                  "type": "string",
                  "enum": ["manifest", "tokens", "contracts", "components", "screens", "flows", "platform", "locales"]
                }
              },
              "scope": {
                "type": "string",
                "description": "What code belongs in this shared layer (e.g. 'Business logic, data models, repositories, API clients, view models. No UI rendering.')"
              }
            },
            "required": ["platforms", "language", "root", "scope"],
            "additionalProperties": false
          }
        },
        "structure": {
          "type": "object",
          "description": "Per-target output directory structure (overrides heuristic code root discovery)",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "root": {
                "type": "string"
              },
              "paths": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "scope": {
                "type": "string",
                "description": "What code belongs in this target directory (e.g. 'Pure SwiftUI views and navigation. All business logic comes from the shared layer.')"
              }
            },
            "required": ["root"],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "targets"
      ],
      "additionalProperties": false
    },
    "formatters": {
      "type": "object",
      "description": "Custom formatter definitions for format expressions",
      "additionalProperties": {
        "$ref": "https://openuispec.rsteam.uz/schema/openuispec.schema.json#/$defs/formatter_def"
      }
    },
    "mappers": {
      "type": "object",
      "description": "Key-value mapping definitions",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      }
    },
    "data_model": {
      "type": "object",
      "description": "Application data model definitions",
      "additionalProperties": {
        "$ref": "https://openuispec.rsteam.uz/schema/openuispec.schema.json#/$defs/model_def"
      }
    },
    "custom_contracts": {
      "type": "array",
      "description": "Paths to custom contract definition files (x_ prefixed)",
      "items": {
        "type": "string"
      }
    },
    "design": {
      "type": "object",
      "description": "Design intent and anti-patterns for this project",
      "properties": {
        "personality": { "type": "string", "description": "Brief description of the brand's visual personality" },
        "complexity": {
          "type": "string",
          "enum": ["restrained", "balanced", "elaborate"],
          "default": "balanced",
          "description": "How elaborate animations, effects, and visual details should be"
        },
        "audience": { "type": "string", "description": "Who uses this app — informs tone and complexity" },
        "quality_tier": {
          "type": "string",
          "enum": ["mvp", "production", "flagship"],
          "default": "production",
          "description": "Quality bar — mvp: functional-only, production: polished with full tokens, flagship: pixel-perfect with every state and motion pattern"
        },
        "avoid": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Project-specific anti-patterns. May use [web]/[ios]/[android] scope tags."
        }
      },
      "additionalProperties": false
    },
    "generation_guidance": {
      "type": "object",
      "description": "Universal anti-patterns and audit config for AI generators",
      "properties": {
        "universal_anti_patterns": {
          "type": "object",
          "description": "Cross-contract anti-patterns by domain",
          "properties": {
            "typography": { "type": "array", "items": { "type": "string" } },
            "color": { "type": "array", "items": { "type": "string" } },
            "spacing": { "type": "array", "items": { "type": "string" } },
            "motion": { "type": "array", "items": { "type": "string" } },
            "elevation": { "type": "array", "items": { "type": "string" } },
            "layout": { "type": "array", "items": { "type": "string" } },
            "visual": { "type": "array", "items": { "type": "string" } },
            "interaction": { "type": "array", "items": { "type": "string" } },
            "accessibility": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "audit_threshold": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum design quality score. Default 0 (informational). --min-score CLI flag takes precedence."
        }
      },
      "additionalProperties": false
    },
    "api": {
      "type": "object",
      "description": "API endpoint definitions",
      "properties": {
        "base_url": {
          "type": "string"
        },
        "auth": {
          "type": "string"
        },
        "endpoints": {
          "type": "object",
          "description": "Grouped API endpoints",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "$ref": "https://openuispec.rsteam.uz/schema/openuispec.schema.json#/$defs/endpoint_def"
            }
          }
        }
      },
      "required": [
        "base_url",
        "endpoints"
      ],
      "additionalProperties": false
    }
  },
  "$defs": {
    "formatter_def": {
      "type": "object",
      "properties": {
        "input": {
          "type": "string"
        },
        "output": {
          "type": "string"
        },
        "mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "input",
        "output",
        "mapping"
      ],
      "additionalProperties": false
    },
    "model_def": {
      "type": "object",
      "description": "Data model \u2014 map of field names to field definitions",
      "additionalProperties": {
        "$ref": "https://openuispec.rsteam.uz/schema/openuispec.schema.json#/$defs/field_def"
      }
    },
    "field_def": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "max_length": {
          "type": "integer"
        },
        "default": {},
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "endpoint_def": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "path": {
          "type": "string"
        },
        "params": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "body": {}
      },
      "required": [
        "method",
        "path"
      ],
      "additionalProperties": false
    }
  }
}
