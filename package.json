{
  "name": "openuispec",
  "version": "0.2.5",
  "license": "MIT",
  "type": "module",
  "description": "A semantic UI specification format for AI-native, platform-native app development",
  "homepage": "https://openuispec.rsteam.uz",
  "repository": {
    "type": "git",
    "url": "https://github.com/rsktash/openuispec.git"
  },
  "files": [
    "cli/",
    "check/",
    "drift/",
    "mcp-server/",
    "prepare/",
    "status/",
    "schema/",
    "spec/",
    "docs/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "openuispec": "./cli/index.ts",
    "openuispec-mcp": "./mcp-server/index.ts"
  },
  "scripts": {
    "test": "node --import tsx --test tests/check.test.ts tests/configure-target.test.ts tests/drift-prepare.test.ts tests/init.test.ts tests/mcp-tools.test.ts tests/semantic-lint.test.ts tests/status.test.ts",
    "test:screenshot": "node --import tsx --test tests/mcp-screenshot.test.ts",
    "test:all": "node --import tsx --test tests/*.test.ts",
    "validate": "tsx schema/validate.ts",
    "validate:manifest": "tsx schema/validate.ts manifest",
    "validate:tokens": "tsx schema/validate.ts tokens",
    "validate:screens": "tsx schema/validate.ts screens",
    "validate:flows": "tsx schema/validate.ts flows",
    "validate:platform": "tsx schema/validate.ts platform",
    "validate:locales": "tsx schema/validate.ts locales",
    "drift": "tsx drift/index.ts",
    "drift:snapshot": "tsx drift/index.ts --snapshot --target",
    "prepare:target": "tsx prepare/index.ts",
    "status": "tsx status/index.ts",
    "postinstall": "echo \"\\n  ✓ openuispec installed — if upgrading, run: openuispec update-rules\\n\"",
    "cloc": "cloc --exclude-dir=$(tr '\n' ',' < .cloc-ignore) ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.19.4",
    "yaml": "^2.7.1"
  },
  "optionalDependencies": {
    "puppeteer": "^24.39.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.3"
  }
}
